---
- name: Skapa användare och grupper på alla maskiner
  hosts: all
  become: true
  vars_files:
    - group_vars/all.yml

  tasks:
    - name: Uppdatera apt-cache
      apt:
        update_cache: true
        cache_valid_time: 3600

    - name: Skapa grupper
      group:
        name: "{{ item.name }}"
        gid: "{{ item.gid }}"
        state: present
      loop: "{{ groups_to_create }}"

    - name: Skapa användare
      user:
        name: "{{ item.name }}"
        uid: "{{ item.uid }}"
        groups: "{{ item.groups }}"
        append: true
        shell: /bin/bash
        create_home: true
        state: present
      loop: "{{ users_to_create }}"
      
- name: Konfigurera NFS-server
  hosts: nfs_server
  become: true
  vars_files:
    - group_vars/all.yml

  tasks:
    - name: Installera NFS-server
      apt:
        name: nfs-kernel-server
        state: present
        update_cache: true

    - name: Skapa huvudkatalog för shares
      file:
        path: /shares
        state: directory
        owner: root
        group: root
        mode: "0755"

    - name: Skapa kataloger för shares
      file:
        path: "{{ item.path }}"
        state: directory
        owner: root
        group: "{{ item.group }}"
        mode: "{{ item.mode }}"
      loop: "{{ shares }}"

    - name: Konfigurera NFS exports
      copy:
        dest: /etc/exports
        content: |
          {% for share in shares %}
          {{ share.path }} {{ nfs_network }}(rw,sync,no_subtree_check,root_squash)
          {% endfor %}
      notify: Ladda om NFS exports

    - name: Starta och aktivera NFS-server
      service:
        name: nfs-kernel-server
        state: started
        enabled: true

  handlers:
    - name: Ladda om NFS exports
      command: exportfs -ra